# Neon Postgres connection string used by Prisma at runtime (pooled).
# Provisioned automatically by the Vercel Neon integration; run
# `vercel env pull .env.local` to fetch real values, or copy them from the
# Neon dashboard.
DATABASE_URL=""

# Neon direct (non-pooled) connection string, used by Prisma for migrations.
DATABASE_URL_UNPOOLED=""

# Auth.js (NextAuth v5) — random secret used to sign/encrypt session tokens.
# Generate one with: npx auth secret
AUTH_SECRET=""
